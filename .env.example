# MedTelegramBot — Environment Configuration
# Copy this file: cp .env.example .env

# Telegram Bot
BOT_TOKEN=your_bot_token_here

# LLM Primary (Gemini — бесплатный лимит 60 запросов/мин)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# LLM Fallback 1 (OpenRouter → DeepSeek V4 Flash)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# LLM Fallback 2 (OpenCode Zen → Big Pickle — бесплатно)
OPENCODE_ZEN_API_KEY=your_opencode_zen_api_key_here
OPENCODE_ZEN_MODEL=big-pickle

# Telegram API Proxy (Happ VPN)
PROXY_URL=http://127.0.0.1:10809
PROXY_URL_SOCKS=socks5://127.0.0.1:10809

# Database (локально SQLite, на Render — PostgreSQL от Render Dashboard)
# Render: postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=sqlite+aiosqlite:///data/medbot.db

# Render.com deploy (true = отключает EasyOCR, включает Tesseract)
# RENDER_DEPLOY=true

# Server
HOST=0.0.0.0
PORT=8080

# Admin
ADMIN_ID=your_telegram_id

# Logging
LOG_LEVEL=INFO

# Robokassa Payment Gateway (оставьте пустым, если не используется)
# ROBOKASSA_LOGIN=
# ROBOKASSA_PASSWORD1=
# ROBOKASSA_PASSWORD2=
